# Database
DATABASE_URL="postgresql://installplan:installplan_secret@localhost:5434/installationsplan?schema=public"

# Auth.js
AUTH_SECRET="generate-a-secure-secret-here-change-in-production"
AUTH_URL="http://localhost:3100"

# Redis
REDIS_URL="redis://localhost:6380"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9002
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin_secret"
MINIO_BUCKET="installationsplan"
MINIO_USE_SSL=false

# SMTP (Email Sending)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-password"
SMTP_FROM="noreply@example.com"

# IMAP (Email Import)
IMAP_HOST="imap.example.com"
IMAP_PORT=993
IMAP_USER="your-email@example.com"
IMAP_PASS="your-password"
IMAP_FOLDER="INBOX"
IMAP_POLL_INTERVAL_MINUTES=5

# App
NEXT_PUBLIC_APP_URL="http://localhost:3100"
